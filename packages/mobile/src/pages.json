{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "少女游戏盒子",
        "navigationStyle": "custom",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/my/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/detail/index",
      "style": {
        "navigationBarTitleText": "游戏详情",
        "navigationBarBackgroundColor": "#ffffff",
        "navigationBarTextStyle": "black",
        "app-plus": {
          "titleNView": {
            "buttons": [
              {
                "type": "share",
                "fontSize": "22px",
                "color": "#333333"
              }
            ]
          }
        }
      }
    },
    {
      "path": "pages/search/index",
      "style": {
        "navigationBarTitleText": "搜索页",
        "navigationBarBackgroundColor": "#ffffff",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/category/detail",
      "style": { "navigationStyle": "custom", "enablePullDownRefresh": true, "backgroundTextStyle": "dark" }
    },
    {
      "path": "pages/my/gifts",
      "style": { "navigationStyle": "custom", "enablePullDownRefresh": true, "backgroundTextStyle": "dark" }
    },
    {
      "path": "pages/my/favorites",
      "style": {
        "navigationBarTitleText": "我的收藏",
        "navigationBarBackgroundColor": "#ffffff"
      }
    },
    {
      "path": "pages/my/footprints",
      "style": {
        "navigationBarTitleText": "最近浏览",
        "navigationBarBackgroundColor": "#ffffff"
      }
    },
    {
      "path": "pages/webview/index",
      "style": { "navigationBarTitleText": "详情" }
    },
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "欢迎登录",
        "navigationStyle": "custom"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "App 盒子",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f5f5f5"
  },
  "tabBar": {
    "custom": true,
    "color": "#94a3b8",
    "selectedColor": "#6366f1",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "精选"
      },
      {
        "pagePath": "pages/my/index",
        "text": "我的"
      }
    ]
  }
}
