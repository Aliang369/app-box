{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "少女游戏盒子",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/my/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/detail/index",
      "style": {
        "navigationBarTitleText": "游戏详情"
      }
    },
    {
      "path": "pages/search/index",
      "style": {
        "navigationBarTitleText": "搜索页",
        "navigationBarBackgroundColor": "#ffffff"
      }
    },
    {
      "path": "pages/latest/index",
      "style": {
        "navigationBarTitleText": "最新上线",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/rank/index",
      "style": {
        "navigationBarTitleText": "排行榜单",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/gift/index",
      "style": {
        "navigationBarTitleText": "专属福利",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/category/index",
      "style": {
        "navigationBarTitleText": "分类大全",
        "navigationStyle": "custom"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "App 盒子",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f5f5f5"
  },
  "tabBar": {
    "custom": true,
    "color": "#94a3b8",
    "selectedColor": "#6366f1",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "精选"
      },
      {
        "pagePath": "pages/my/index",
        "text": "我的"
      }
    ]
  }
}
